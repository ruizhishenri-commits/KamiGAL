<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1524"
    android:keepScreenOn="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- 光晕 -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center">

            <View
                android:id="@+id/splashGlow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/splash_glow"
                android:alpha="0.6" />

            <ImageView
                android:id="@+id/splashLogo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_raw"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_logo_circle"
                android:clipToOutline="true" />
        </FrameLayout>

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="KamiGAL"
            android:textColor="@color/yh_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/splashLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/yh_text_muted"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
